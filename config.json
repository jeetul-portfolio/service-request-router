{
  "port": 8080,
  "rules": [
    {
      "name": "argocd",
      "hostname": "argocd.jeetulsamaiya.com",
      "prefix": "/",
      "host": "http://argocd-server.argocd.svc.cluster.local:80",
      "sort": 20
    },
    {
      "name": "core",
      "prefix": "/apis/core",
      "host": "http://core.portfolio.svc.cluster.local:8080",
      "sort": 10
    },
    {
      "name": "fallback-regex",
      "regex": "^/.*",
      "host": "http://demo-svc.default.svc.cluster.local:80",
      "sort": 1
    }
  ]
}
