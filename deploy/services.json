{
  "general": {
    "namespace": "portfolio",
    "preStartImage": "busybox:1.36",
    "resources": {
      "requests": {
        "cpu": "100m",
        "memory": "128Mi"
      },
      "limits": {
        "cpu": "250m",
        "memory": "256Mi"
      }
    }
  },
  "deployments": [
    {
      "name": "service-request-router",
      "replicas": 1,
      "image": "docker.io/jeetulsamaiya1/portfolio:service-request-router-master-1012",
      "containerPort": 8080,
      "containerCommand": [
        "/app/service-request-router"
      ],
      "preStartCommands": [
        "echo Preparing service-request-router before startup",
        "echo Pre-start checks completed"
      ],
      "service": {
        "type": "ClusterIP",
        "port": 8080,
        "targetPort": 8080
      },
      "configMounts": [],
      "containerArgs": [
        "-config",
        "/app/config.json"
      ]
    }
  ]
}
