{
  "port": 8080,
  "rules": [
    {
      "name": "core-v2",
      "prefix": "/core/v2",
      "host": "http://localhost:9002",
      "sort": 10
    },
    {
      "name": "core",
      "prefix": "/core",
      "host": "http://localhost:9001",
      "sort": 10
    },
    {
      "name": "health",
      "exact": "/health",
      "host": "http://localhost:9010",
      "sort": 20
    },
    {
      "name": "fallback-regex",
      "regex": "^/v[0-9]+/.*$",
      "host": "http://localhost:9020",
      "sort": 1
    }
  ]
}
